# Manufacturers
COMPANY_CODE=1177
# Ruuvi Gateway config endpoint auth
# Use Basic OR Bearer depending on how you configure the gateway
GW_CFG_USER=ruuvi-cfg
GW_CFG_PASSWORD=<mot-de-passe-fort>
GW_CFG_BEARER_TOKEN=<token-optionnel>
# Mapping Gateway MAC → name label
GATEWAY_NAMES='{"F3:2D:EF:E7:2E:78":"Station 1","C8:25:2D:8E:9C:2C":"Station 2"}'
# Mapping Tag MAC → name label
TAG_NAMES='{"CE:52:DE:73:84:F2":"Frigo 1","AB:CD:EF:12:34:56":"Congélateur"}'
# MQTT
MQTT_HOST=localhost
MQTT_PORT=8883
MQTT_PROTOCOL=mqtts
MQTT_TOPIC='ruuvi/#'
# Auth
MQTT_USERNAME=
MQTT_PASSWORD=
# TLS
MQTT_CA='<path to ca.crt>'
MQTT_CERT='<path to gateway.crt>'
MQTT_KEY='<path to gateway.key>'
MQTT_REJECT_UNAUTHORIZED=true
# HTTP
NODE_ENV=development
HTTP_PORT=3002
BUFFER_SIZE=500
FLUSH_INTERVAL=5000
HTTP_API_KEY=<token># Generate a random API key, e.g. using `openssl rand -hex 32` or using API key Genrator in https://www.strongdm.com/tools/api-key-generator
# Storage backend: "influxdb" | "mariadb" | "both"
STORAGE_BACKEND=both
# Influx
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=<token>
INFLUX_ORG=ruuvi-org
INFLUX_BUCKET=ruuvi
# MariaDB
MARIA_HOST=localhost
MARIA_PORT=3306
MARIA_USER=ruuvi
MARIA_PASSWORD=<password>
MARIA_DATABASE=ruuvi
MARIA_BUFFER_SIZE=100
# ── MariaDB Retention & Downsampling ──
# Enable automatic retention of raw data
MARIA_RETENTION_ENABLED=true
# Retention period for raw data (days)
MARIA_RETENTION_DAYS=60
# Enable hourly downsampling
MARIA_DOWNSAMPLE_ENABLED=true
# Retention period for downsampled data (days, 0 = infinity)
MARIA_DOWNSAMPLE_RETENTION_DAYS=365
# Delete the raw data that has already been downsampled
MARIA_DOWNSAMPLE_DELETE_RAW=true
# Task execution interval (cron-like, in hours)
MARIA_MAINTENANCE_INTERVAL_HOURS=6

DEBUG_GW=true