{
  "name": "ruuvi-iot-ingestion",
  "version": "3.2.0",
  "description": "High-performance RuuviTag MQTT ingestion service for InfluxDB and/or MariaDB",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "packageManager": "pnpm@11.0.1",
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@influxdata/influxdb-client": "^1.35.0",
    "advlib-ble-manufacturers": "^1.15.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "json-schema-to-zod": "^2.7.0",
    "mqtt": "^5.3.3",
    "mysql2": "^3.20.0",
    "ojousima.ruuvi_endpoints.ts": "^4.0.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.18.0",
    "vitest": "^4.1.5"
  }
}
